# ZTK GUI Makefile
CC      = gcc
CFLAGS  = -O2 -Wall -Wextra -std=c11
LDFLAGS = -lm

PREFIX  ?= ../build/rootfs

.PHONY: all clean install

all: ztkgui

ztkgui: ztkgui.c
	$(CC) $(CFLAGS) -o $@ $< $(LDFLAGS)
	@echo "[GUI] Built ztkgui"

install: ztkgui
	install -Dm755 ztkgui $(PREFIX)/bin/ztkgui

clean:
	rm -f ztkgui *.o
